# CockroachDB / PostgreSQL Database Settings
# You can supply DATABASE_URL or individual SQL_* / COCKROACH_* parameters:
DATABASE_URL="postgresql://root@localhost:26257/defaultdb?sslmode=disable"
SQL_HOST="primary-cockroach.server.com"
SQL_BACKUP_HOST="secondary-cockroach.server.com" # Secondary backup server for reliability/failover
SQL_PORT="26257"
SQL_USER="root"
SQL_PASSWORD=""
SQL_DB_NAME="defaultdb"
SQL_SSL="false"

# RustFS / S3-Compatible Object Storage Settings
# When configured, uploaded media will be stored directly in RustFS S3
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="rustfsadmin"
S3_SECRET_ACCESS_KEY="rustfspassword"
S3_BUCKET_NAME="imamu-uploads"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"
# S3_PUBLIC_URL="http://localhost:9000/imamu-uploads"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# SMTP Settings for sending verification emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="example@gmail.com"
SMTP_PASS="password"

